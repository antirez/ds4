+    __shared__ float partial[256];
+    __shared__ float max_s;
+    __shared__ float denom;
+    float local_max = sinks[h];
+    const uint32_t visible_comp = (t + 1u) / ratio;
+    for (uint32_t k = threadIdx.x; k < n_keys; k += blockDim.x) {
+        float s = -INFINITY;
