+        uint32_t                n_tokens) {
+    (void)group_tmp;
+    (void)low_tmp;
+    if (!out || !low || !heads || !model_map ||
+        group_dim == 0 || rank == 0 || n_groups == 0 || out_dim == 0 || n_tokens == 0) {
+        return 0;
+    }
