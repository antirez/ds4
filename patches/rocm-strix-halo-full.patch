+                                                      (int)head_dim,
+                                                      0,
+                                                      (const float *)q->ptr,
+                                                      (int)(n_head * head_dim),
+                                                      (long long)head_dim,
+                                                      &beta,
+                                                      scores,
+                                                      (int)n_keys,
+                                                      (long long)n_keys * n_tokens,
+                                                      (int)n_head);
