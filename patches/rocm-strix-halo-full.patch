+                    dim3 tgrid((out_dim + 31u) / 32u, down_tile_capacity, 1);
+                    moe_down_expert_tile8_row32_kernel<<<tgrid, 256>>>(
+                        use_atomic_down ? (float *)out->ptr : (float *)down->ptr,
+                        down_w, midq, sorted_pairs, sorted_offsets, sorted_counts,
