+                                       HIPBLAS_OP_N,
+                                       HIPBLAS_OP_N,
+                                       (int)head_dim,
+                                       (int)n_tokens,
+                                       (int)n_keys,
+                                       &one,
+                                       (const float *)raw_kv->ptr,
+                                       (int)head_dim,
+                                       0,
+                                       scores,
+                                       (int)n_keys,
+                                       (long long)n_keys * n_tokens,
+                                       &beta,
+                                       out_tmp,
+                                       (int)head_dim,
+                                       (long long)head_dim * n_tokens,
+                                       (int)n_head);
