+        uint64_t n_tok) {
+    uint64_t row = (uint64_t)blockIdx.x;
+    uint64_t tok = (uint64_t)blockIdx.y;
+    if (row >= out_dim || tok >= n_tok) return;
+    const uint64_t blocks = (in_dim + 31) / 32;
+    const unsigned char *wr = w + row * blocks * 34;
+    const float *xr = x + tok * in_dim;
+    float acc = 0.0f;
