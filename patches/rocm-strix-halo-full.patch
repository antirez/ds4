+__global__ static void attention_prefill_mixed_softmax_kernel(
+        float *scores,
+        const float *sinks,
+        const float *comp_mask,
+        uint32_t use_comp_mask,
+        uint32_t n_tokens,
+        uint32_t n_comp,
+        uint32_t window,
+        uint32_t ratio,
+        uint32_t n_keys) {
+    uint32_t t = blockIdx.x;
+    uint32_t h = blockIdx.y;
