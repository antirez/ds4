+                                                                        out_tmp,
+                                                                        n_tokens,
+                                                                        n_head,
+                                                                        head_dim);
+        return cuda_ok(hipGetLastError(), "attention mixed unpack launch");
+    }
+    dim3 grid(n_tokens, n_head, 1);
+    attention_prefill_mixed_kernel<<<grid, 256>>>((float *)heads->ptr,
+                                                  sinks,
+                                                  (const float *)q->ptr,
