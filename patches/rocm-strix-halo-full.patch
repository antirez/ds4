+                                                      HIPBLAS_OP_T,
+                                                      HIPBLAS_OP_N,
+                                                      (int)n_keys,
+                                                      (int)n_tokens,
+                                                      (int)head_dim,
+                                                      &alpha,
+                                                      kv,
+                                                      (int)head_dim,
+                                                      0,
+                                                      (const float *)q->ptr,
+                                                      (int)(n_head * head_dim),
+                                                      (long long)head_dim,
+                                                      &beta,
