        "DS4_MTP_ACCEPT_TRACE": "1",
        "DS4_MTP_NO_ACCEPT_GATE": "1",
        "DS4_MTP_EXACT_DECODE2": "1",
        "DS4_MTP_NO_CERT_LOGITS": "1"
